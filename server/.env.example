# Ambiente
NODE_ENV=development
PORT=3001

# Banco de dados (obrigatório)
MONGODB_URI=mongodb://localhost:27017/consulte-seu-processo

# Autenticação (obrigatório — mínimo 32 caracteres)
JWT_SECRET=sua-chave-secreta-com-pelo-menos-32-caracteres
JWT_EXPIRES_IN=7d

# Frontend (obrigatório em produção — usado no CORS e links de e-mail)
FRONTEND_URL=http://localhost:3000

# Cookie (opcional — se omitido, deriva automaticamente de FRONTEND_URL em produção)
# Ex: FRONTEND_URL=https://app.candidopereira.com.br → domain .candidopereira.com.br
# COOKIE_DOMAIN=.candidopereira.com.br

# E-mail (obrigatório em produção — envio de link para definir senha)
# IMPORTANTE: EMAIL_HOST deve apontar para o servidor cPanel onde a conta existe.
# Se mail.seudominio.com.br resolver para IP errado, use o hostname do cPanel (ex: srv232.prodns.com.br).
EMAIL_HOST=smtp.exemplo.com
EMAIL_PORT=587
EMAIL_USER=seu@email.com
EMAIL_PASS=sua-senha
EMAIL_FROM="Consulte seu Processo <noreply@seudominio.com>"
# EMAIL_TLS_SERVERNAME=mail.seudominio.com.br  # use se EMAIL_HOST for o hostname do cPanel, não mail.seudominio
# EMAIL_SECURE=true          # use true para porta 465
# EMAIL_TLS_REJECT_UNAUTHORIZED=false  # apenas se o servidor SMTP usar certificado inválido

# Seed do admin (usado apenas com npm run seed)
ADMIN_EMAIL=admin@email.com
ADMIN_PASSWORD=admin123
