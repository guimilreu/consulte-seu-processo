# Ambiente
NODE_ENV=development
PORT=3001

# Banco de dados (obrigatório)
MONGODB_URI=mongodb://localhost:27017/consulte-seu-processo

# Autenticação (obrigatório — mínimo 32 caracteres)
JWT_SECRET=sua-chave-secreta-com-pelo-menos-32-caracteres
JWT_EXPIRES_IN=7d

# Frontend (obrigatório em produção — usado no CORS e links de e-mail)
FRONTEND_URL=http://localhost:3000

# Cookie (opcional — se omitido, deriva automaticamente de FRONTEND_URL em produção)
# Ex: FRONTEND_URL=https://app.candidopereira.com.br → domain .candidopereira.com.br
# COOKIE_DOMAIN=.candidopereira.com.br

# E-mail via Resend (obrigatório em produção)
# 1. Crie conta em https://resend.com
# 2. Verifique o domínio em https://resend.com/domains (adicione os registros DNS indicados)
# 3. Crie uma API key em https://resend.com/api-keys
RESEND_API_KEY=re_sua_chave_aqui
EMAIL_FROM="Consulte seu Processo <no-reply@seudominio.com>"
# EMAIL_REPLY_TO=contato@seudominio.com

# Seed do admin (usado apenas com npm run seed)
ADMIN_EMAIL=admin@email.com
ADMIN_PASSWORD=admin123
